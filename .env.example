# Para Vercel + Supabase + Prisma:
# DATABASE_URL = URL do pooler
# DIRECT_URL   = URL direta do banco
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/postgres?sslmode=require"
AUTH_SECRET="substitua-por-um-segredo-forte"
AUTH_URL="https://seu-projeto.vercel.app"
AUTH_TRUST_HOST="true"

# Opcional (Google OAuth)
# Em desenvolvimento: http://localhost:3000/api/auth/callback/google
# Em produção: https://seu-projeto.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
