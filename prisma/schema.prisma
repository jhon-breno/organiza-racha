generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Modality {
  FUTEBOL
  FUTSAL
  VOLEI
  BASQUETE
  BEACH_TENNIS
  TENIS
  CORRIDA
  OUTRO
}

enum Visibility {
  OPEN
  PRIVATE
}

enum RachaStatus {
  PUBLISHED
  CANCELED
  COMPLETED
}

enum ParticipantLevel {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

enum ParticipantStatus {
  ACTIVE
  WAITLIST
  CANCELED
}

enum PaymentStatus {
  PENDING
  PROOF_SENT
  PAID
  REFUND_REQUESTED
  REFUNDED
}

model User {
  id            String       @id @default(cuid())
  name          String?
  nickname      String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  phone         String?      @unique
  passwordHash  String?
  passwordResetToken   String? @unique
  passwordResetExpires DateTime?
  pixKey        String?
  pixBankName   String?
  pixHolderName String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  sessions      Session[]
  rachas        Racha[]
  enrollments   Enrollment[]
}

model Racha {
  id                      String         @id @default(cuid())
  slug                    String         @unique
  title                   String
  modality                Modality
  description             String?
  rules                   String
  athleteLimit            Int
  eventDate               DateTime
  locationName            String
  address                 String
  city                    String
  state                   String?
  mapsQuery               String?
  priceInCents            Int
  organizerDisplayName    String
  phoneWhatsapp           String
  whatsappGroupUrl        String?
  pixKey                  String
  coverImageUrl           String?
  profileImageUrl         String?
  visibility              Visibility     @default(OPEN)
  accessKey               String?
  cancellationWindowHours Int            @default(2)
  paymentDeadline         DateTime?
  status                  RachaStatus    @default(PUBLISHED)
  // Futebol
  futebolType             String?
  goalkeeperLimit         Int?
  // Vôlei
  voleiType               String?
  hasFixedSetter          Boolean        @default(false)
  setterLimit             Int?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  organizerId             String
  organizer               User           @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  enrollments             Enrollment[]

  @@index([eventDate])
  @@index([city])
  @@index([organizerId])
}

model Enrollment {
  id                 String            @id @default(cuid())
  participantName    String
  participantPhone   String
  participantPosition String
  participantLevel   ParticipantLevel
  acceptedRules      Boolean
  pixPaid            Boolean           @default(false)
  notes              String?
  status             ParticipantStatus @default(ACTIVE)
  paymentStatus      PaymentStatus     @default(PENDING)
  canceledAt         DateTime?
  refundRequestedAt  DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  rachaId            String
  userId             String
  racha              Racha             @relation(fields: [rachaId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rachaId, userId])
  @@index([rachaId, status])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
